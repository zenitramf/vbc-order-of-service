{
  "name": "tanstack-start-example-basic-cloudflare",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "deploy": "pnpm build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "auth:generate": "pnpm dlx auth@latest generate --config auth.ts --yes",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:migrate:local": "wrangler d1 migrations apply vbc-order-of-service --local",
    "db:migrate:remote": "wrangler d1 migrations apply vbc-order-of-service --remote",
    "postinstall": "pnpm cf-typegen",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@better-auth/infra": "^0.3.4",
    "@better-auth/passkey": "^1.6.23",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-start": "^1.168.26",
    "@tanstack/react-table": "^8.21.3",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "1.0.0-rc.4",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.1",
    "radix-ui": "^1.6.0",
    "react": "^19.0.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "3.8.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.20.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.6",
    "drizzle-kit": "1.0.0-rc.4",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.2",
    "ultracite": "^7.8.3",
    "vite": "^8.0.14",
    "vitest": "^3.2.6",
    "wrangler": "^4.103.0"
  }
}
